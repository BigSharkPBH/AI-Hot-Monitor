# ===== 敏感配置（绝不提交）=====
.env
.env.local
.env.*.local
server/.env
server/.env.*
!server/.env.example
!.env.example

# ===== 数据库文件（运行时生成）=====
server/data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ===== Node.js 依赖 =====
node_modules/
client/node_modules/
server/node_modules/

# ===== 构建产物 =====
client/dist/
client/.vite/
server/dist/

# ===== 日志 =====
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
server/logs/

# ===== 操作系统文件 =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ===== 编辑器目录 =====
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ===== 运行时临时文件 =====
*.pid
*.seed
*.pid.lock
.npm/
.eslintcache
.stylelintcache
